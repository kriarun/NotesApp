{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeycloakOptions": {
    "TokenUrl": "https://keycloak.example.com/realms/myrealm/protocol/openid-connect/token",
